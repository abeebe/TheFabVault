# ─── Auth ──────────────────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-64-char-random-secret
JWT_TTL=43200

# ─── Ports ─────────────────────────────────────────────────────────
# WEB_PORT: host port for the UI  (default 80 — change to e.g. 8080 if port 80 is taken)
# API_PORT: host port for the API (default 3000)
API_PORT=3000
WEB_PORT=8080

# ─── Frontend (build-time) ─────────────────────────────────────────
# Must be reachable by the USER'S BROWSER, not by containers.
# Always match API_PORT here — this value is baked into the web image at build time.
VITE_API_URL=http://YOUR_SERVER_IP:3000

# ─── CORS ──────────────────────────────────────────────────────────
# Must match the origin the browser uses to load the UI.
#   WEB_PORT=80   →  CORS_ORIGINS=http://YOUR_SERVER_IP          (no port, 80 is implicit)
#   WEB_PORT=8080 →  CORS_ORIGINS=http://YOUR_SERVER_IP:8080     (port required)
CORS_ORIGINS=http://YOUR_SERVER_IP:8080

# ─── Import Scan ───────────────────────────────────────────────────
# Extensions to import (comma-separated, leave empty for defaults: stl,obj,3mf,svg,dxf,png,jpg,jpeg,webp,gcode,gc,g)
IMPORT_MOUNT_EXTS=
# Set to false to disable auto-scan of network mounts on startup
IMPORT_MOUNT_ON_STARTUP=true
# Max file size per file in MB
IMPORT_MAX_MB=512

# ─── Network Mounts (Admin UI approach — recommended) ──────────────
# NFS and SMB/CIFS shares are configured via the Admin Settings panel in the UI.
# No env vars required here. The docker-compose.yml includes cap_add: [SYS_ADMIN]
# which allows the container to mount shares directly.
# See DEPLOYMENT.md → "Network Mounts" for setup details.

# ─── NFS Storage (docker-compose.nfs.yml alternative) ─────────────
# Use these vars if you prefer Docker-managed NFS volumes instead of the Admin UI.
# Run with: docker compose -f docker-compose.nfs.yml up -d
#NFS_STORAGE_HOST=192.168.1.100
#NFS_STORAGE_PATH=/mnt/tank/fabvault/storage
#NFS_DATA_PATH=/mnt/tank/fabvault/db
#NFS_VERSION=4
#NFS_IMPORT_1_PATH=/mnt/tank/3d-prints
#NFS_IMPORT_2_PATH=
#NFS_IMPORT_3_PATH=

# ─── SMB Storage (docker-compose.smb.yml alternative) ─────────────
# Use these vars if you prefer Docker-managed SMB volumes instead of the Admin UI.
# Run with: docker compose -f docker-compose.smb.yml up -d
#SMB_STORAGE_HOST=192.168.1.100
#SMB_STORAGE_SHARE=fabvault/storage
#SMB_DATA_SHARE=fabvault/db
#SMB_USERNAME=fabuser
#SMB_PASSWORD=yourpassword
#SMB_VERSION=3.0
#SMB_IMPORT_1_SHARE=media/3d-prints
#SMB_IMPORT_2_SHARE=
#SMB_IMPORT_3_SHARE=
