# ─── Auth ──────────────────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-64-char-random-secret
JWT_TTL=43200

# ─── Ports ─────────────────────────────────────────────────────────
# WEB_PORT: host port for the UI  (default 80 — change to e.g. 8080 if port 80 is taken)
# API_PORT: host port for the API (default 3000)
API_PORT=3000
WEB_PORT=8080

# ─── Frontend (build-time) ─────────────────────────────────────────
# Must be reachable by the USER'S BROWSER, not by containers.
# Always match API_PORT here — this value is baked into the web image at build time.
VITE_API_URL=http://YOUR_SERVER_IP:3000

# ─── CORS ──────────────────────────────────────────────────────────
# Must match the origin the browser uses to load the UI.
#   WEB_PORT=80   →  CORS_ORIGINS=http://YOUR_SERVER_IP          (no port, 80 is implicit)
#   WEB_PORT=8080 →  CORS_ORIGINS=http://YOUR_SERVER_IP:8080     (port required)
CORS_ORIGINS=http://YOUR_SERVER_IP:8080

# ─── NAS / Mount Import ────────────────────────────────────────────
# Host path to your NAS mount, mapped read-only to /imports in container.
# Leave empty (or comment out) to disable NAS import entirely.
IMPORT_MOUNT_PATH_HOST=
# Container-internal path — must match the volume target in docker-compose.yml (do not change)
IMPORT_MOUNT_PATH=/imports
# Extensions to import (comma-separated, leave empty for defaults: stl,obj,3mf,svg,dxf,png,jpg,jpeg,webp,gcode,gc,g)
IMPORT_MOUNT_EXTS=
# Set to false to disable auto-scan on startup
IMPORT_MOUNT_ON_STARTUP=true
# Max file size per file in MB
IMPORT_MAX_MB=512
